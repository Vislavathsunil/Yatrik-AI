{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID" },
        "name": { "type": "string", "description": "The full display name" },
        "email": { "type": "string", "description": "The email address" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "provider": { "type": "string", "description": "Authentication provider" },
        "emailVerified": { "type": "boolean", "description": "Whether user's email is verified" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "subscriptionPlan": { "type": "string", "description": "User's tier or plan" },
        "tripCount": { "type": "integer", "description": "Total trips generated" }
      },
      "required": ["uid", "name", "email", "provider", "createdAt", "lastLogin"]
    },
    "trip": {
      "title": "Saved Trip Plan",
      "description": "A travel itinerary generated by YatrikAI",
      "type": "object",
      "properties": {
        "tripId": { "type": "string", "description": "Trip unique identifier" },
        "destination": { "type": "string", "description": "Target destination" },
        "startingLocation": { "type": "string", "description": "Point of origin" },
        "startDate": { "type": "string", "description": "Trip start date" },
        "endDate": { "type": "string", "description": "Trip end date" },
        "numberOfDays": { "type": "integer", "description": "Number of days" },
        "budget": { "type": "string", "description": "Selected budget level" },
        "travelers": { "type": "string", "description": "Number of travelers or type" },
        "travelStyle": { "type": "string", "description": "Style of travel" },
        "interests": { "type": "array", "description": "User chosen interests" },
        "generatedItinerary": { "type": "object", "description": "Complete day-wise travel details" },
        "hotelRecommendations": { "type": "array", "description": "Recommended lodging list" },
        "transportRecommendations": { "type": "array", "description": "Recommended transportation modes" },
        "estimatedBudget": { "type": "object", "description": "Cost breakdown overview" },
        "weatherInformation": { "type": "object", "description": "Destination weather insights" },
        "packingChecklist": { "type": "array", "description": "Dynamic baggage packing items" },
        "tripStatus": { "type": "string", "description": "Lifecycle state: upcoming, past, ongoing" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Saved creation time" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["tripId", "destination", "numberOfDays", "generatedItinerary", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "user",
      "description": "User profiles root documents"
    },
    "users/{uid}/trips/{tripId}": {
      "schema": "trip",
      "description": "Day-wise travel plans saved for each user"
    }
  }
}
